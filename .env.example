# Copie este arquivo para .env e preencha com seus valores.
# Nunca commite o arquivo .env (ele já está no .gitignore).

# Chave da API OpenAI (obrigatória para a análise por IA)
OPENAI_API_KEY=sk-proj-...

# Modelo opcional (padrão: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# Opcional: credenciais de login CW (se usar formulário interno)
# CW_USER=seu_usuario
# CW_PASSWORD=sua_senha
